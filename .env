# Full configuration options https://github.com/JayDDee/cpuminer-opt

# -------------------------------
# CPU configuration
# -------------------------------

# Fraction of total available CPU cores to allocate to cpuminer.
# This value is used to calculate the number of mining threads (-t).
# Example:
#   0.25 on a 4-core CPU → ~1 thread
#   0.50 on a 4-core CPU → ~2 threads
#
# Minimum value is 0.01 (practically), and it will always resolve to at least 1 thread.
CPU_FRACTION=0.25

# Docker CPU limit (optional).
# Controls how much CPU time the container is allowed to use.
# Recommended to keep aligned with CPU_FRACTION for consistent behavior.
# Example:
#   0.25 = container may use up to 25% of a single CPU core's time
CPUS=0.25

# -------------------------------
# Mining configuration
# -------------------------------

# Stratum pool URL (required)
POOL=stratum+tcp://your_pool:port

# Wallet address (required)
WALLET=your_wallet_address

# Worker name (optional, useful for debugging and identification)
# If set, will be appended as: wallet.worker
WORKER=worker_name

# Pool password (usually "x" for most pools)
PASSWORD=x

# Mining algorithm
# Must be supported by cpuminer-opt, full list: https://github.com/JayDDee/cpuminer-opt/blob/master/README.md
ALGO=sha256d

# -------------------------------
# Optional advanced flags
# -------------------------------

# Additional flags passed directly to cpuminer-opt
# Example:
# EXTRA_FLAGS=--api-bind=0.0.0.0:4028
EXTRA_FLAGS=
